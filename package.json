{
  "name": "owlpay-sdk",
  "version": "1.0.2",
  "description": "TypeScript SDK for the OwlPay Harbor API",
  "license": "MIT",
  "author": "Igbiriki Francis <francis.igbiriki@gmail.com>",
  "keywords": [
    "owlpay",
    "harbor",
    "payments",
    "remittance",
    "crypto",
    "sdk",
    "typescript"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  }
}
